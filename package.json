{
  "name": "aws-sftp-testbed",
  "version": "0.1.0",
  "private": true,
  "description": "Disposable AWS SFTP testbed for integration testing.",
  "type": "module",
  "scripts": {
    "verify:structure": "node tools/check-structure.mjs",
    "verify:public-sanitization": "node tools/check-public-sanitization.mjs",
    "verify:shell-static": "node tools/check-shell-static.mjs",
    "verify:cloudformation-static": "node tools/check-cloudformation-static.mjs",
    "verify:bootstrap-static": "node tools/check-bootstrap-static.mjs",
    "verify:docs": "node tools/check-docs-whitespace.mjs",
    "verify:scoped": "node tools/run-verification.mjs",
    "verify:safe": "node tools/run-verification.mjs preset:safe",
    "verify:list": "node tools/run-verification.mjs --list",
    "verify:recommend:dirty": "node tools/run-verification.mjs --recommend --dirty",
    "login": "node tools/run-bash-script.mjs scripts/login.sh",
    "validate:routine-access": "node tools/run-bash-script.mjs scripts/validate-routine-access.sh",
    "deploy": "node tools/run-bash-script.mjs scripts/deploy.sh",
    "bootstrap:inspect": "node tools/run-bash-script.mjs bootstrap/scripts/inspect.sh",
    "bootstrap:create-account": "node tools/run-bash-script.mjs bootstrap/scripts/create-account.sh",
    "bootstrap:ensure-permission-set": "node tools/run-bash-script.mjs bootstrap/scripts/ensure-permission-set.sh",
    "bootstrap:assign-permission-set": "node tools/run-bash-script.mjs bootstrap/scripts/assign-permission-set.sh",
    "bootstrap:configure-profile": "node tools/run-bash-script.mjs bootstrap/scripts/configure-routine-profile.sh --bootstrap --approve-local-profile",
    "start": "node tools/run-bash-script.mjs scripts/start.sh",
    "stop": "node tools/run-bash-script.mjs scripts/stop.sh",
    "destroy": "node tools/run-bash-script.mjs scripts/destroy.sh --approve-destroy",
    "describe": "node tools/run-bash-script.mjs scripts/describe.sh",
    "update:parameter": "node tools/run-bash-script.mjs scripts/update-parameter.sh",
    "read:parameter": "node tools/run-bash-script.mjs scripts/read-parameter.sh",
    "diagnostics:enable": "node tools/run-bash-script.mjs scripts/enable-diagnostics.sh",
    "diagnose:source-ip": "node tools/run-bash-script.mjs scripts/diagnose-source-ip.sh",
    "diagnostics:disable": "node tools/run-bash-script.mjs scripts/disable-diagnostics.sh",
    "smoke:test": "node tools/run-bash-script.mjs scripts/smoke-test.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonecutter-hierophant/aws-sftp-testbed.git"
  },
  "keywords": [
    "aws",
    "sftp",
    "cloudformation",
    "integration-testing"
  ],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/bonecutter-hierophant/aws-sftp-testbed/issues"
  }
}
